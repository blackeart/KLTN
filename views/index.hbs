<html>
  <head>
    <meta charset='utf-8' />
    <title>VTI Academy Clone</title>
    <link rel='stylesheet' href='/css/style.css' />
  </head>
  <body>
    <div class='top-bar'>
      <span>📞 CS Hà Nội: <b>0866.805.563</b></span>
      <span>📞 CS Đà Nẵng: <b>0968.834.386</b></span>
      <span>📞 CS HCM: <b>0978.067.066</b></span>
    </div>

    <header class='main-header'>
      <div class='logo'>
        <img
          src='	https://vtiacademy.edu.vn/upload/images/academy-02-01-01-01.png'
          alt='Logo'
        />
      </div>

      <ul class='nav-menu'>
        <li><a href='#'>Về chúng tôi</a></li>
        <li><a href='#'>Khóa học</a></li>
        <li><a href='#'>Lịch khai giảng</a></li>
        <li><a href='#'>Đào tạo doanh nghiệp</a></li>
        <li><a href='#'>Đối tác</a></li>
        <li><a href='#'>Học viên</a></li>
        <li><a href='#'>Liên hệ</a></li>
      </ul>

      <div class='search-icon'>🔍</div>
    </header>

    <main>
      <div class='slider-container'>
        <div class='slide active'>
          <img
            src='https://vtiacademy.edu.vn/upload/images/data-04.png'
            alt='Cơ hội vàng học 1 được 2'
          />
        </div>

        <div class='slide'>
          <img
            src='https://vtiacademy.edu.vn/upload/images/z7612463236164-00b70c414107f3daeaf7653e959da8b8.jpg'
            alt='Khóa học lập trình'
          />
        </div>

        <div class='slide'>
          <img
            src='https://vtiacademy.edu.vn/upload/images/tuan-le-vang-1-04.png'
            alt='Khóa học lập trình'
          />
        </div>

        <button class='slider-btn prev-btn'>❮</button>
        <button class='slider-btn next-btn'>❯</button>
      </div>
    </main>

    <section class='feature-container'>
      <div class='feature-content'>
        <div class='feature-image'>
          <img
            src='https://vtiacademy.edu.vn/upload/images/anh-2-trang-chu-vi-sao-nen-hoc-o-vti-academy-29.7.2025.jpg'
            alt='Lý do lựa chọn VTI Academy'
          />
        </div>

        <div class='feature-action'>
          <a href='#' class='btn-more'>
            Xem thêm về điểm khác biệt của VTI Academy
            <span>›</span>
          </a>
        </div>
      </div>
    </section>

    <section class='courses-section'>
      <h2 class='section-title'>Chương trình đào tạo</h2>

      <div class='courses-slider'>
        <div class='courses-wrapper'>
          <div class='course-card'>
            <div class='card-image'>
              <img
                src='https://vtiacademy.edu.vn/upload/images/ba-for-banking-2-01.jpg'
                alt='Data Analyst'
              />
            </div>
            <p class='course-name'>Khóa Học Data Analyst</p>
          </div>

          <div class='course-card'>
            <div class='card-image'>
              <img
                src='https://vtiacademy.edu.vn/upload/images/jb1-01(1).png'
                alt='Business Analyst'
              />
            </div>
            <p class='course-name'>Khóa Học BA</p>
          </div>

          <div class='course-card'>
            <div class='card-image'>
              <img
                src='https://vtiacademy.edu.vn/upload/images/artboard-1-copy-4.png'
                alt='AWS SAA'
              />
            </div>
            <p class='course-name'>Khóa Học AWS Certified Solutions Architect -
              Associate</p>
          </div>

          <div class='course-card'>
            <div class='card-image'>
              <img
                src='https://vtiacademy.edu.vn/upload/images/data-analyst-2-01.png'
                alt='AWS SAA'
              />
            </div>
            <p class='course-name'>Khóa Học Data Analyst</p>
          </div>
        </div>

        <div class='slider-dots'>
          <span class='dot active'></span>
          <span class='dot'></span>
        </div>
      </div>

      <div class='courses-action'>
        <button class='btn-view-all'>Xem thêm</button>
      </div>
    </section>

    <!-- Nút bấm gọi chat box -->
    <div class='floating-widgets'>
      <a href='#contact-section' class='widget-item consult-btn'>
        <span>NHẬN<br />TƯ VẤN</span>
      </a>

      <div class='widget-item chat-toggle-btn' id='chat-btn'>
        <div class='chat-icon'>
          <svg viewBox='0 0 24 24' width='30' height='30' fill='currentColor'>
            <path
              d='M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm0 14H5.17L4 17.17V4h16v12z'
            />
            <circle cx='7' cy='9' r='1.25' /><circle
              cx='12'
              cy='9'
              r='1.25'
            /><circle cx='17' cy='9' r='1.25' />
          </svg>
        </div>
      </div>
    </div>

    <div class='chat-window' id='chat-window'>
      <div class='chat-header'>
        <span>AI Admission Assistant</span>
        <button id='close-chat'>×</button>
      </div>
      <div class='chat-body' id='chat-body'>
        <div class='message bot'>Chào bạn! Tôi có thể giúp gì cho bạn về thông
          tin tuyển sinh của VTI Academy?</div>
      </div>
      <div class='chat-footer'>
        <input
          type='text'
          id='chat-input'
          placeholder='Nhập câu hỏi tại đây...'
        />
        <button id='send-btn'>➤</button>
      </div>
    </div>
    <script src='/js/script.js'></script>
  </body>
</html>